# 洛克王国远行商人 - 环境变量示例
# 复制为 .env 或直接在 docker-compose.yaml 的 environment 中填写

# ── 必填 ──
WEGAME_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Bark 推送 ──
BARK_ENABLED=true
BARK_KEY=你的BarkKey
BARK_SERVER=https://bark.momolab.cc
BARK_ICON=https://d1.aag.moe/public/2026/04/27/91e1e7cbf665f0a4.png

# ── 飞书（可选，留空则不推送） ──
FEISHU_HOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── 钉钉（可选） ──
DINGTALK_TOKEN=
DINGTALK_SECRET=

# ── Discord（可选） ──
DISCORD_HOOK=
